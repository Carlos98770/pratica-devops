                  "mappings": [
                    {
                      "options": {
                        "0": {
                          "index": 1,
                          "text": "DOWN"
                        },
                        "1": {
                          "index": 0,
                          "text": "UP"
                        }
                      },
                      "type": "value"
                    }
                  ],
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "blue",
                        "value": 0
                      },
                      {
                        "color": "red",
                        "value": 0
                      },
                      {
                        "color": "dark-green",
                        "value": 1
